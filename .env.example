# POA Association - Environment Variables

# Database Connection (Required)
DATABASE_URL=postgresql://user:password@host:5432/database

# Session Secret (Required) — signs the session cookie. Changing it invalidates
# all existing sessions. Generate with: openssl rand -hex 32
SESSION_SECRET=your-random-secret-string

# App URL — base for absolute links in all transactional emails (invites,
# billing, plus auth verification / password-reset). Falls back to the
# request's protocol + host if unset. Example: https://poassociation.com
APP_URL=

# Email delivery (Required for verification + password-reset emails)
# SMTP2GO API key. If unset, those emails are skipped (logged, non-fatal).
SMTP2GO_API_KEY=

# Super Admin Access (Required for Admin UI)
# Semicolon-delimited list of email addresses that have super admin privileges
# Example: admin@company.com;manager@company.com;superuser@company.com
SUPER_ADMIN_EMAILS=

# Node Environment
NODE_ENV=development

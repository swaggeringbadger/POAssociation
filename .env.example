# POA Association - Environment Variables

# Database Connection (Required)
DATABASE_URL=postgresql://user:password@host:5432/database

# Replit Auth (Required for OAuth login)
# Get these from: https://replit.com/@username/appname > Security > Identity
REPL_ID=your-repl-id
REPLIT_DB_URL=https://kv.replit.com/v0/your-db-url

# Super Admin Access (Required for Admin UI)
# Semicolon-delimited list of email addresses that have super admin privileges
# Example: admin@company.com;manager@company.com;superuser@company.com
SUPER_ADMIN_EMAILS=

# Session Secret (Optional - auto-generated if not set)
SESSION_SECRET=your-random-secret-string

# Node Environment
NODE_ENV=development
